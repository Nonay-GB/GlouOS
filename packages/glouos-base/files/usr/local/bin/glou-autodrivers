#!/bin/bash
set -u

pac() { pacman -S --noconfirm --needed "$@" || echo "GlouOS: skipped '$*' (not available / no internet)"; }

gpu="$(lspci -nn 2>/dev/null | grep -Ei 'vga|3d|display' || true)"
net="$(lspci -nn 2>/dev/null | grep -Ei 'network|ethernet' || true)"
echo "GlouOS hardware setup"
echo "  GPU:     ${gpu:-none}"
echo "  Network: ${net:-none}"

if echo "$gpu" | grep -qi nvidia; then
    echo "  -> NVIDIA GPU: proprietary driver"
    pac nvidia-dkms nvidia-utils lib32-nvidia-utils nvidia-settings
fi
if echo "$gpu" | grep -Eqi 'amd|ati|radeon'; then
    echo "  -> AMD GPU: RADV (mesa + vulkan-radeon)"
    pac vulkan-radeon lib32-vulkan-radeon
fi
if echo "$gpu" | grep -qi intel; then
    echo "  -> Intel GPU: ANV (mesa + vulkan-intel)"
    pac vulkan-intel lib32-vulkan-intel
fi

echo "  -> Audio firmware (sof-firmware / alsa-firmware)"
pac sof-firmware alsa-firmware

if echo "$net" | grep -qi broadcom; then
    echo "  -> Broadcom Wi-Fi: trying broadcom-wl-dkms"
    pac broadcom-wl-dkms
fi

echo "GlouOS hardware setup done."
exit 0
